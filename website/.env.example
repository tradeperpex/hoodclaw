# =============================================================================
# AgentClaw — environment variables
#
# Local:  copy to website/.env.local
# Vercel: Settings → Environment Variables (root directory = website)
# =============================================================================


# --- Public (safe in browser) ---

# Site URL for metadata / Open Graph
NEXT_PUBLIC_SITE_URL=https://theagentcompany.fun

# Token mint — used for pump.fun buy links on the website
NEXT_PUBLIC_MINT_ADDRESS=

# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://uyfnpybfptpfivwxjxyv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV5Zm5weWJmcHRwZml2d3hqeHl2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0MDE1MjMsImV4cCI6MjA5Nzk3NzUyM30.0KMDvHjq2t7bCQLYgwKh_yrsy5k-1PCiW9lSSfJeklY


# --- Agent (server only — never expose) ---

# Base58 secret key for the agent wallet.
# Must be the pump.fun coin creator (collects creator fees on-chain).
AGENT_PRIVATE_KEY=

# Same value as NEXT_PUBLIC_MINT_ADDRESS
MINT_ADDRESS=

# Supabase service role — Settings → API (bypasses RLS, cron + API writes)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV5Zm5weWJmcHRwZml2d3hqeHl2Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MjQwMTUyMywiZXhwIjoyMDk3OTc3NTIzfQ.6zccW0DB7U7WDOKID6exGaHfAAq9zDHnZvvzVnJwY6A
# Vercel sets this automatically when cron is enabled
CRON_SECRET=3123b1a4ebaa1a17f5e2c180f32df11f51ce365bb0eeeace34a2dbd7263f47d5


# --- Solana RPC (server only — strongly recommended) ---

# Public mainnet RPC rate-limits fast. Use Helius, QuickNode, etc.
RPC_URL=https://mainnet.helius-rpc.com/?api-key=2a4a408c-b846-4df8-bacc-0dc7938b1429


# --- Optional ---

# AI-generated thoughts + chat replies (Kie / OpenAI-compatible)
KIE_API_KEY=f6055c59eb98346a67cc20b98d0f9521

# Min SOL in creator vault before agent runs a cycle (default 0.01)
MIN_CLAIM_SOL=0.01

# Agent tuning (defaults shown)
# CYCLE_INTERVAL_MS=60000
# RPC_DELAY_MS=200

# Fallback if RPC_URL is unset (prefer RPC_URL server-side only)
# NEXT_PUBLIC_RPC_URL=
