# =============================================================================
# HoodClaw — Robinhood Chain (chain ID 4663)
#
# Local:  copy to website/.env.local
# Vercel: Settings → Environment Variables (root directory = website)
# =============================================================================


# --- Public (safe in browser) ---

NEXT_PUBLIC_SITE_URL=https://thehoodclaw.fun
NEXT_PUBLIC_X_URL=https://x.com/hoodchainclaw

# HoodClaw ERC-20 token — Uniswap buy links on the website
NEXT_PUBLIC_TOKEN_ADDRESS=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Agent (server only — never expose) ---

# EVM private key for the agent treasury wallet (hex, with or without 0x)
AGENT_PRIVATE_KEY=

# Same as NEXT_PUBLIC_TOKEN_ADDRESS
TOKEN_ADDRESS=

SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Robinhood Chain RPC
RPC_URL=

# --- Optional ---

KIE_API_KEY=
MIN_CLAIM_ETH=0.01

# Legacy Solana env names still accepted by older agent code paths:
# MINT_ADDRESS=  MIN_CLAIM_SOL=0.01
